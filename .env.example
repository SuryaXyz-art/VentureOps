# App
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
VENTUREOPS_APP_URL=http://localhost:3000
DEMO_MODE=true
AGENT_POLICY_MODE=shadow

# Database
DATABASE_URL="file:./dev.db"

# Stripe test mode. Use test keys only. Do not commit real secrets.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# LLM provider. Use mock for offline demo, hermes for local NemoHermes/Nemotron.
LLM_PROVIDER=hermes
HERMES_BASE_URL=http://127.0.0.1:8642/v1
HERMES_API_URL=http://127.0.0.1:8642/v1
HERMES_MODEL=hermes-agent
HERMES_API_KEY=

# Optional direct OpenAI-compatible adapters. NEMOTRON_MODEL_ID is only for direct NVIDIA adapter usage, not local Hermes.
NOUS_API_KEY=
NOUS_BASE_URL=
NOUS_MODEL_ID=
NVIDIA_API_KEY=
NVIDIA_BASE_URL=
NEMOTRON_MODEL_ID=nvidia/nemotron-3-ultra-550b-a55b

# Optional safe-runtime documentation hook.
NEMOCLAW_RUNTIME_URL=
# Public submission links. Leave blank until final submission URLs are ready.
NEXT_PUBLIC_GITHUB_URL=
NEXT_PUBLIC_LIVE_DEMO_URL=
NEXT_PUBLIC_PRODUCT_POST_URL=
NEXT_PUBLIC_VIDEO_URL=


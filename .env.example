# App
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
VENTUREOPS_APP_URL=http://localhost:3000
DEMO_MODE=true

# Database
DATABASE_URL="file:./dev.db"

# Stripe test mode. Use test keys only. Do not commit real secrets.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# LLM provider. Use mock for offline demo, hermes for local NemoHermes/Nemotron.
LLM_PROVIDER=mock
HERMES_BASE_URL=http://127.0.0.1:8642/v1
HERMES_MODEL=hermes-agent
HERMES_API_KEY=
NOUS_API_KEY=
NVIDIA_API_KEY=
NVIDIA_BASE_URL=
NOUS_BASE_URL=
